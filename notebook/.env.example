# pydantic-ai native: vercel:provider/model (e.g. vercel:openai/gpt-5.4-mini)
# legacy alias: vercel_ai_gateway/provider/model
LLM_MODEL=openai/gpt-5-nano
LLM_API_KEY=
LLM_TEMPERATURE=1.0
LLM_REASONING_EFFORT=
# SEMHASH dedup embedding model (model2vec StaticModel HF id)
# Default when unset: minishlab/potion-multilingual-128M
SEMHASH_MODEL=minishlab/potion-multilingual-128M
LLM_SSL_VERIFY=true
